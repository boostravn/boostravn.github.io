# PostHog project (public) key. Copy from PostHog → Project Settings → API Keys.
# Safe to expose client-side; it only allows event ingestion, not data reads.
PUBLIC_POSTHOG_KEY=phc_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional. Defaults to https://us.i.posthog.com.
# Use https://eu.i.posthog.com for the EU cloud or your self-hosted URL.
PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
