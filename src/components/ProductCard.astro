---
import { landing } from "../content/landing";
import Logo from "./Logo.astro";
const { product } = landing.hero;
---
<div class="relative rounded-3xl overflow-hidden border-2 border-(--color-gold) shadow-[0_30px_70px_-20px_rgba(22,32,24,0.55)]">

  <!-- Image / placeholder area -->
  <div class="relative aspect-[4/3] overflow-hidden bg-(--color-forest-deep)">
    {product.image ? (
      <img
        src={product.image.src}
        alt={product.image.alt}
        class="w-full h-full object-cover object-center transition-transform duration-700 hover:scale-[1.04]"
        loading="eager"
      />
    ) : (
      <div class="w-full h-full flex items-center justify-center">
        <Logo variant="light" class="w-48 h-auto opacity-80" ariaLabel="" />
      </div>
    )}

    <!-- Bottom gradient so tags/info blends on dark bg -->
    <div class="absolute inset-0 bg-gradient-to-t from-(--color-forest-deep)/70 via-(--color-forest-deep)/10 to-transparent pointer-events-none"></div>

    <!-- Floating tags -->
    <div class="absolute top-4 left-4 right-4 flex items-start justify-between gap-2">
      <span class="text-(--color-gold) text-[10px] font-bold tracking-[0.2em] uppercase bg-(--color-forest-deep)/65 backdrop-blur-sm px-3 py-1.5 rounded-full border border-(--color-gold)/30">
        {product.tagTop}
      </span>
      <!-- <span class="inline-flex items-center px-3 py-1.5 rounded-full bg-(--color-gold) text-(--color-forest) text-[11px] font-bold tracking-[0.08em]"> -->
      <!--   {product.tagRight} -->
      <!-- </span> -->
    </div>
  </div>

  <!-- Info strip -->
  <div class="relative bg-(--color-forest-deep) px-6 py-5 flex items-center justify-between gap-4">
    <div class="min-w-0">
      <div class="inline-flex items-center px-3 py-1.5 rounded-full border border-(--color-gold)/50 text-(--color-cream) text-sm font-medium leading-snug">
        {product.title}
      </div>
      <p class="mt-2 text-xs text-(--color-cream)/55 tracking-wide">{product.footer}</p>
    </div>

    <!-- Sticker -->
    <div
      class="shrink-0 rotate-[5deg] bg-(--color-gold) text-(--color-forest) rounded-2xl px-3 py-2 text-xs font-semibold leading-snug max-w-[140px] shadow-lg"
      aria-hidden="true"
    >
      <span>{product.stickerEmoji} {product.sticker}</span>
    </div>
  </div>
</div>
