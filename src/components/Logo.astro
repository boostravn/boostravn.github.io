---
interface Props {
  variant?: "dark" | "light";
  size?: number;
  class?: string;
  ariaLabel?: string;
}

const {
  variant = "dark",
  class: className = "",
  ariaLabel = "Boostra — Herbal Tea, EST 2027",
} = Astro.props;

// On dark backgrounds the dark-green PNG needs to be lightened to cream
const filterStyle = variant === "light"
  ? "filter: brightness(0) invert(1) sepia(0.12);"
  : "";
---
<img
  src="/images/logo.png"
  alt={ariaLabel}
  class={className}
  style={filterStyle}
  draggable="false"
/>
