---
import { landing } from "../content/landing";
import { ShoppingBag } from "lucide-react";

const { products } = landing;
---
<section id="cua-hang" class="py-16 lg:py-24 bg-(--color-cream-soft)/40" aria-labelledby="products-heading">
  <div class="max-w-[1200px] mx-auto px-6">
    <div class="text-center">
      <span class="section-eyebrow bg-(--color-cream-strong) text-(--color-forest)">
        {products.badge}
      </span>
      <h2 id="products-heading" class="mt-5 text-3xl sm:text-4xl lg:text-[40px] font-bold text-(--color-forest)">
        {products.heading}
      </h2>
    </div>

    <div class="mt-12 grid grid-cols-1 md:grid-cols-2 gap-6 lg:gap-8">
      {products.items.map((item) => {
        const isHighlight = item.highlight === true;
        const cardStyle = isHighlight
          ? "bg-(--color-cream-strong) border-(--color-gold) shadow-[0_18px_40px_-24px_rgba(47,95,44,0.35)]"
          : "bg-(--color-cream-soft) border-(--color-forest)/15";
        const priceColor = isHighlight
          ? "text-(--color-rust)"
          : "text-(--color-forest)";
        const badgeStyle =
          item.badge.tone === "gold"
            ? "bg-(--color-gold) text-(--color-forest)"
            : "bg-(--color-forest)/10 text-(--color-forest)";
        const [single, combo] = item.variants;
        return (
          <article
            class={`relative rounded-3xl border-2 overflow-hidden ${cardStyle} flex flex-col text-(--color-forest)`}
            data-product-card
            data-variant="single"
          >
            <div class="relative aspect-[4/3] bg-(--color-cream) overflow-hidden">
              <img
                src={single.image.src}
                alt={single.image.alt}
                data-variant-image="single"
                class="absolute inset-0 w-full h-full object-contain p-5 transition-opacity duration-400"
                loading="lazy"
              />
              <img
                src={combo.image.src}
                alt={combo.image.alt}
                data-variant-image="combo"
                class="absolute inset-0 w-full h-full object-contain p-5 opacity-0 transition-opacity duration-400"
                loading="lazy"
                aria-hidden="true"
              />
            </div>

            <div class="p-7 sm:p-9 flex flex-col flex-1">
              <div class="flex flex-wrap items-center gap-3">
                <div
                  role="tablist"
                  aria-label={`Chọn quy cách cho ${single.name}`}
                  class="inline-flex p-1 rounded-full bg-(--color-forest)/8 border border-(--color-forest)/10"
                  data-variant-tabs
                >
                  {item.variants.map((v) => {
                    const key = v.qty === 1 ? "single" : "combo";
                    const isDefault = key === "single";
                    return (
                      <button
                        type="button"
                        role="tab"
                        data-variant-tab={key}
                        aria-selected={isDefault ? "true" : "false"}
                        class="px-4 py-1.5 rounded-full text-xs sm:text-sm font-semibold text-(--color-forest)/70 aria-selected:bg-(--color-forest) aria-selected:text-(--color-cream) aria-selected:shadow-sm transition-colors focus:outline-none focus-visible:outline-2 focus-visible:outline-(--color-forest) focus-visible:outline-offset-2"
                      >
                        {v.qtyLabel}
                      </button>
                    );
                  })}
                </div>
                <span
                  class="text-xs sm:text-sm font-medium text-(--color-forest)/70 tabular-nums"
                  data-variant-spec
                >
                  {single.spec}
                </span>
              </div>

              <div class="mt-5 flex items-center justify-between gap-3 flex-wrap">
                <span class={`inline-flex items-center px-3 py-1 rounded-full text-[11px] font-bold tracking-[0.1em] uppercase ${badgeStyle}`}>
                  {item.badge.label}
                </span>
                <span class={`text-2xl sm:text-3xl font-bold tabular-nums ${priceColor}`} data-variant-price>
                  {single.price}
                </span>
              </div>

              <h3 class="mt-5 text-xl sm:text-2xl font-bold leading-snug" data-variant-name>
                {single.name}
              </h3>
              <p class="mt-3 text-sm sm:text-[15px] leading-relaxed text-(--color-forest)/80 flex-1" data-variant-description>
                {single.description}
              </p>

              <!-- <p -->
              <!--   class="mt-4 inline-flex self-start items-center gap-2 px-3 py-1.5 rounded-full text-xs font-semibold border transition-colors duration-300" -->
              <!--   data-variant-savings -->
              <!-- > -->
              <!--   <span aria-hidden="true" data-variant-savings-emoji>💰</span> -->
              <!--   <span data-variant-savings-text>{combo.savingsHint ?? ""}</span> -->
              <!-- </p> -->
            </div>

            <script type="application/json" data-variant-payload={`payload-${item.id}`} set:html={JSON.stringify({
              single: {
                name: single.name,
                spec: single.spec,
                price: single.price,
                description: single.description,
                savingsText: combo.savingsHint ?? "",
                savingsEmoji: "💰",
                savingsTone: "hint",
              },
              combo: {
                name: combo.name,
                spec: combo.spec,
                price: combo.price,
                description: combo.description,
                savingsText: combo.savings ?? "",
                savingsEmoji: "✓",
                savingsTone: "confirm",
              },
            })} />
          </article>
        );
      })}
    </div>

    <div class="mt-10 flex flex-wrap items-center justify-center gap-3">
      <a
        href={products.cta.href}
        class="inline-flex items-center gap-2 bg-(--color-forest) hover:bg-(--color-forest-deep) text-(--color-cream) font-semibold px-6 py-3.5 rounded-xl transition-colors focus-ring-gold"
      >
        <ShoppingBag size={18} aria-hidden="true" />
        {products.cta.label}
      </a>
    </div>
  </div>
</section>

<script>
  type VariantKey = "single" | "combo";
  type SavingsTone = "hint" | "confirm";
  interface VariantPayload {
    name: string;
    spec: string;
    price: string;
    description: string;
    savingsText: string;
    savingsEmoji: string;
    savingsTone: SavingsTone;
  }

  document.querySelectorAll<HTMLElement>("[data-product-card]").forEach((card) => {
    const payloadScript = card.querySelector<HTMLScriptElement>("script[type='application/json']");
    if (!payloadScript) return;
    let payload: { single: VariantPayload; combo: VariantPayload };
    try {
      payload = JSON.parse(payloadScript.textContent ?? "{}");
    } catch {
      return;
    }

    const tabs = card.querySelectorAll<HTMLButtonElement>("[data-variant-tab]");
    const images = card.querySelectorAll<HTMLImageElement>("[data-variant-image]");
    const nameEl = card.querySelector<HTMLElement>("[data-variant-name]");
    const specEl = card.querySelector<HTMLElement>("[data-variant-spec]");
    const priceEl = card.querySelector<HTMLElement>("[data-variant-price]");
    const descEl = card.querySelector<HTMLElement>("[data-variant-description]");
    const savingsEl = card.querySelector<HTMLElement>("[data-variant-savings]");
    const savingsText = card.querySelector<HTMLElement>("[data-variant-savings-text]");
    const savingsEmoji = card.querySelector<HTMLElement>("[data-variant-savings-emoji]");

    if (savingsEmoji) savingsEmoji.textContent = payload.single.savingsEmoji;
    if (savingsText) savingsText.textContent = payload.single.savingsText;

    function activate(key: VariantKey) {
      card.dataset.variant = key;
      tabs.forEach((tab) => {
        const match = tab.dataset.variantTab === key;
        tab.setAttribute("aria-selected", match ? "true" : "false");
      });
      images.forEach((img) => {
        const match = img.dataset.variantImage === key;
        img.style.opacity = match ? "1" : "0";
        img.setAttribute("aria-hidden", match ? "false" : "true");
      });
      const data = payload[key];
      if (nameEl) nameEl.textContent = data.name;
      if (specEl) specEl.textContent = data.spec;
      if (priceEl) priceEl.textContent = data.price;
      if (descEl) descEl.textContent = data.description;
      if (savingsEmoji) savingsEmoji.textContent = data.savingsEmoji;
      if (savingsText) savingsText.textContent = data.savingsText;

      if (typeof window !== "undefined" && window.posthog) {
        window.posthog.capture("product_variant_selected", {
          card_id: card.id || undefined,
          variant: key,
        });
      }
    }

    tabs.forEach((tab) => {
      tab.addEventListener("click", () => {
        const key = (tab.dataset.variantTab as VariantKey | undefined) ?? "single";
        activate(key);
      });
    });
  });

  declare global {
    interface Window {
      posthog?: { capture: (event: string, properties?: Record<string, unknown>) => void };
    }
  }
</script>
