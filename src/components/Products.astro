---
import { landing } from "../content/landing";
import { ShoppingBag } from "lucide-react";

const { products } = landing;
---
<section id="cua-hang" class="py-16 lg:py-24 bg-(--color-cream-soft)/40" aria-labelledby="products-heading">
  <div class="max-w-[1200px] mx-auto px-6">
    <div class="text-center">
      <span class="section-eyebrow bg-(--color-cream-strong) text-(--color-forest)">
        {products.badge}
      </span>
      <h2 id="products-heading" class="mt-5 text-3xl sm:text-4xl lg:text-[40px] font-bold text-(--color-forest)">
        {products.heading}
      </h2>
    </div>

    <div class="mt-12 grid grid-cols-1 md:grid-cols-2 gap-6 lg:gap-8">
      {products.items.map((item) => {
        const isHighlight = item.highlight === true;
        const cardStyle = isHighlight
          ? "bg-(--color-cream-strong) border-(--color-gold) shadow-[0_18px_40px_-24px_rgba(47,95,44,0.35)]"
          : "bg-(--color-cream-soft) border-(--color-forest)/15";
        const priceColor = isHighlight
          ? "text-(--color-rust)"
          : "text-(--color-forest)";
        const badgeStyle =
          item.badge.tone === "gold"
            ? "bg-(--color-gold) text-(--color-forest)"
            : "bg-(--color-forest)/10 text-(--color-forest)";
        return (
          <article class={`group relative rounded-3xl border-2 overflow-hidden ${cardStyle} flex flex-col text-(--color-forest)`}>
            {item.image && (
              <div class="relative aspect-[4/3] bg-(--color-cream) overflow-hidden">
                <img
                  src={item.image.src}
                  alt={item.image.alt}
                  class={`absolute inset-0 w-full h-full object-contain p-5 transition-opacity duration-500 ${item.hoverImage ? "group-hover:opacity-0" : ""}`}
                  loading="lazy"
                />
                {item.hoverImage && (
                  <img
                    src={item.hoverImage.src}
                    alt={item.hoverImage.alt}
                    class="absolute inset-0 w-full h-full object-contain p-5 opacity-0 group-hover:opacity-100 transition-opacity duration-500"
                    loading="lazy"
                    aria-hidden="true"
                  />
                )}
                <span class="absolute bottom-3 right-3 inline-flex items-center gap-1.5 text-[10px] font-semibold uppercase tracking-[0.1em] text-(--color-forest)/55 bg-(--color-cream-strong)/85 backdrop-blur-sm px-2.5 py-1 rounded-full opacity-0 group-hover:opacity-100 transition-opacity duration-500 pointer-events-none">
                  Combo 2
                </span>
              </div>
            )}
            <div class="p-7 sm:p-9 flex flex-col flex-1">
              <div class="flex items-center justify-between gap-3">
                <span class={`inline-flex items-center px-3 py-1 rounded-full text-[11px] font-bold tracking-[0.1em] uppercase ${badgeStyle}`}>
                  {item.badge.label}
                </span>
                <span class={`text-2xl sm:text-3xl font-bold ${priceColor}`}>{item.price}</span>
              </div>
              <h3 class="mt-6 text-xl sm:text-2xl font-bold leading-snug">
                {item.name}
              </h3>
              <p class="mt-3 text-sm sm:text-[15px] leading-relaxed text-(--color-forest)/80 flex-1">
                {item.description}
              </p>
            </div>
          </article>
        );
      })}
    </div>

    <div class="mt-10 flex flex-wrap items-center justify-center gap-3">
      <a
        href={products.cta.href}
        class="inline-flex items-center gap-2 bg-(--color-forest) hover:bg-(--color-forest-deep) text-(--color-cream) font-semibold px-6 py-3.5 rounded-xl transition-colors focus-ring-gold"
      >
        <ShoppingBag size={18} aria-hidden="true" />
        {products.cta.label}
      </a>
      <!-- <a -->
      <!--   href={products.ctaSecondary.href} -->
      <!--   class="inline-flex items-center gap-2 bg-(--color-cream) hover:bg-(--color-cream-soft) text-(--color-forest) font-semibold px-6 py-3.5 rounded-xl border-2 border-(--color-forest) transition-colors focus-ring-forest" -->
      <!-- > -->
      <!--   {products.ctaSecondary.label} -->
      <!-- </a> -->
    </div>
  </div>
</section>
