---
import { landing } from "../content/landing";
import { ShoppingBag } from "lucide-react";

const { products } = landing;
---
<section id="cua-hang" class="relative py-20 lg:py-32 bg-(--color-forest-deep) overflow-hidden" aria-labelledby="products-heading">
  <!-- Hairline top / bottom -->
  <div class="absolute top-0 inset-x-0 h-px bg-gradient-to-r from-transparent via-(--color-gold)/35 to-transparent pointer-events-none"></div>
  <div class="absolute bottom-0 inset-x-0 h-px bg-gradient-to-r from-transparent via-(--color-gold)/35 to-transparent pointer-events-none"></div>

  <!-- Ambient glow -->
  <div class="absolute -top-40 left-1/2 -translate-x-1/2 w-[600px] h-[400px] bg-(--color-gold)/5 rounded-full blur-[120px] pointer-events-none"></div>

  <div class="relative max-w-[1200px] mx-auto px-6">

    <!-- Header -->
    <div class="text-center product-reveal">
      <span class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-(--color-gold)/10 border border-(--color-gold)/25 text-(--color-gold) text-[11px] font-semibold tracking-[0.18em] uppercase">
        {products.badge}
      </span>
      <h2 id="products-heading" class="mt-5 text-3xl sm:text-4xl lg:text-[44px] font-bold text-(--color-cream) leading-tight">
        {products.heading}
      </h2>
    </div>

    <!-- Cards -->
    <div class="mt-12 grid grid-cols-1 md:grid-cols-2 gap-5 lg:gap-6">
      {products.items.map((item, i) => {
        const isHighlight = item.highlight === true;
        const [amount, unit] = item.price.split(" / ");
        return (
          <article
            class={`product-reveal relative rounded-2xl p-7 flex flex-col transition-shadow duration-300 ${
              isHighlight
                ? "bg-(--color-forest) ring-2 ring-(--color-gold)/55 hover:ring-(--color-gold)/80 shadow-[0_16px_48px_-16px_rgba(244,211,94,0.18)]"
                : "bg-(--color-forest) ring-1 ring-(--color-cream)/10 hover:ring-(--color-cream)/20"
            }`}
            style={`animation-delay:${0.12 + i * 0.1}s`}
          >
            {isHighlight && (
              <div class="absolute -top-3.5 left-6">
                <span class="inline-flex items-center px-3 py-1 rounded-full bg-(--color-gold) text-(--color-forest) text-[10px] font-bold tracking-[0.12em] uppercase shadow-sm">
                  {item.badge.label}
                </span>
              </div>
            )}

            <div class={`mt-${isHighlight ? "3" : "0"} flex items-baseline gap-2`}>
              <span class={`text-4xl sm:text-5xl font-bold tracking-tight leading-none ${isHighlight ? "text-(--color-gold)" : "text-(--color-cream)"}`}>
                {amount}
              </span>
              <span class="text-(--color-cream)/40 text-sm">/ {unit}</span>
            </div>

            <h3 class="mt-4 text-[15px] sm:text-base font-bold text-(--color-cream) leading-snug">
              {item.name}
            </h3>

            <div class="mt-4 h-px bg-(--color-gold)/20 w-10"></div>

            <p class="mt-4 text-sm leading-relaxed text-(--color-cream)/60 flex-1">
              {item.description}
            </p>

            {!isHighlight && (
              <div class="mt-5">
                <span class="inline-flex items-center px-2.5 py-1 rounded-full bg-(--color-cream)/6 border border-(--color-cream)/12 text-(--color-cream)/55 text-[10px] font-semibold tracking-[0.1em] uppercase">
                  {item.badge.label}
                </span>
              </div>
            )}
          </article>
        );
      })}
    </div>

    <!-- CTA -->
    <div class="mt-6 product-reveal" style="animation-delay:.34s">
      <a
        href={products.cta.href}
        class="group w-full inline-flex items-center justify-center gap-2.5 bg-(--color-gold) hover:bg-(--color-gold-deep) text-(--color-forest) font-bold px-6 py-4 rounded-2xl transition-colors duration-200 focus-ring-gold text-[15px]"
      >
        <ShoppingBag size={18} aria-hidden="true" className="transition-transform duration-200 group-hover:-translate-y-0.5" />
        {products.cta.label}
      </a>
    </div>
  </div>
</section>

<style is:global>
  .product-reveal {
    opacity: 0;
    transform: translateY(18px);
    transition: opacity 0.55s ease, transform 0.55s ease;
  }
  .product-reveal.is-visible {
    opacity: 1;
    transform: translateY(0);
  }
  @media (prefers-reduced-motion: reduce) {
    .product-reveal { opacity: 1; transform: none; transition: none; }
  }
</style>

<script>
  const els = document.querySelectorAll('#cua-hang .product-reveal');
  if (typeof IntersectionObserver !== 'undefined') {
    const io = new IntersectionObserver((entries) => {
      entries.forEach(e => {
        if (e.isIntersecting) {
          const delay = (e.target as HTMLElement).style.animationDelay || '0s';
          const ms = parseFloat(delay) * 1000;
          setTimeout(() => e.target.classList.add('is-visible'), ms);
          io.unobserve(e.target);
        }
      });
    }, { threshold: 0.08 });
    els.forEach(el => io.observe(el));
  } else {
    els.forEach(el => el.classList.add('is-visible'));
  }
</script>
