---
import { landing } from "../content/landing";
import { Leaf, Utensils, Users, Sprout } from "lucide-react";
import type { IconName, TagColor } from "../content/landing";

const iconMap: Record<string, typeof Leaf> = { Leaf, Utensils, Users, Sprout };

const tagStyles: Record<TagColor, string> = {
  green: "bg-(--color-tag-green) text-(--color-cream)",
  orange: "bg-(--color-tag-orange) text-(--color-cream)",
  blue: "bg-(--color-tag-blue) text-(--color-forest)",
  gold: "bg-(--color-tag-gold) text-(--color-forest)",
};

const { activities } = landing;
---
<section id="hoat-dong" class="py-16 lg:py-24" aria-labelledby="activities-heading">
  <div class="max-w-[1200px] mx-auto px-6">
    <div class="text-center">
      <span class="section-eyebrow bg-(--color-cream-strong) text-(--color-forest)">
        {activities.badge}
      </span>
      <h2 id="activities-heading" class="mt-5 text-3xl sm:text-4xl lg:text-[40px] font-bold text-(--color-forest)">
        {activities.heading}
      </h2>
    </div>

    <div class="mt-12 grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
      {activities.items.map((item) => {
        const Icon = iconMap[item.footer.icon as IconName];
        return (
          <article class="rounded-2xl bg-(--color-cream-soft) border border-(--color-forest)/10 p-6 flex flex-col">
            <span class={`inline-flex self-start px-3 py-1 rounded-full text-[11px] font-bold tracking-[0.1em] ${tagStyles[item.tag.color]}`}>
              {item.tag.label}
            </span>
            <h3 class="mt-5 text-lg font-semibold text-(--color-forest) leading-snug">
              {item.title}
            </h3>
            <p class="mt-3 text-sm leading-relaxed text-(--color-forest)/75 flex-1">
              {item.body}
            </p>
            <div class="mt-6 pt-4 border-t border-(--color-forest)/10 flex items-center justify-between text-xs text-(--color-forest)/70">
              <span class="font-medium">{item.footer.label}</span>
              {Icon ? <Icon size={16} aria-hidden="true" /> : null}
            </div>
          </article>
        );
      })}
    </div>
  </div>
</section>
