---
import { landing } from "../content/landing";
import { Brain, HeartPulse, Shield, Coffee, Activity } from "lucide-react";
import type { IconName } from "../content/landing";

const iconMap: Record<string, typeof Brain> = {
  Brain,
  HeartPulse,
  Shield,
  Coffee,
  Activity,
};

const { benefits } = landing;
---
<section id="loi-ich" class="py-16 lg:py-24" aria-labelledby="benefits-heading">
  <div class="max-w-[1200px] mx-auto px-6">
    <div class="text-center">
      <span class="section-eyebrow bg-(--color-cream-strong) text-(--color-forest)">
        {benefits.badge}
      </span>
      <h2 id="benefits-heading" class="mt-5 text-3xl sm:text-4xl lg:text-[40px] font-bold text-(--color-forest)">
        {benefits.heading}
      </h2>
    </div>

    <div class="mt-12 grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
      {benefits.items.map((item) => {
        const Icon = iconMap[item.icon as IconName];
        return (
          <article class="rounded-2xl bg-(--color-cream-soft) border border-(--color-forest)/10 p-6 sm:p-7">
            <div class="w-12 h-12 rounded-full bg-(--color-cream-strong) flex items-center justify-center text-(--color-forest)">
              {Icon ? <Icon size={22} aria-hidden="true" /> : null}
            </div>
            <h3 class="mt-5 text-lg font-semibold text-(--color-forest)">{item.title}</h3>
            <p class="mt-2 text-sm leading-relaxed text-(--color-forest)/75">{item.body}</p>
          </article>
        );
      })}
    </div>
  </div>
</section>
