---
import { landing } from "../content/landing";
import { ShoppingBag, Menu } from "lucide-react";
const { nav } = landing;
---
<header class="sticky top-0 z-50 bg-(--color-cream)/95 backdrop-blur border-b border-(--color-forest)/10">
  <div class="max-w-[1200px] mx-auto px-6 py-3 flex items-center gap-4">
    <a href="#top" class="flex items-center gap-2 shrink-0 focus-ring-forest rounded-md" aria-label="Boostra trang chủ">
      <img src={nav.logo.src} alt={nav.logo.alt} width="120" height="48" class="h-12 w-auto" />
    </a>

    <nav class="hidden lg:flex items-center gap-7 mx-auto" aria-label="Điều hướng chính">
      {nav.links.map((link) => (
        <a
          href={link.href}
          class="text-sm font-medium text-(--color-forest) hover:text-(--color-rust) transition-colors focus-ring-forest rounded-sm"
        >
          {link.label}
        </a>
      ))}
    </nav>

    <div class="flex items-center gap-3 ml-auto">
      <button
        type="button"
        aria-label="Giỏ hàng"
        class="hidden sm:inline-flex w-10 h-10 items-center justify-center rounded-full border border-(--color-forest)/20 text-(--color-forest) hover:bg-(--color-forest) hover:text-(--color-cream) transition-colors focus-ring-forest"
      >
        <ShoppingBag size={18} aria-hidden="true" />
      </button>

      <a
        href={nav.cta.href}
        class="inline-flex items-center gap-1.5 bg-(--color-gold) hover:bg-(--color-gold-deep) text-(--color-forest) font-semibold text-sm px-5 py-2.5 rounded-full border-2 border-(--color-forest) transition-colors focus-ring-forest"
      >
        {nav.cta.label}
        <span aria-hidden="true">›</span>
      </a>

      <button
        type="button"
        aria-label="Mở menu"
        aria-controls="mobile-nav"
        aria-expanded="false"
        id="mobile-nav-toggle"
        class="lg:hidden inline-flex w-10 h-10 items-center justify-center rounded-full text-(--color-forest) focus-ring-forest"
      >
        <Menu size={22} aria-hidden="true" />
      </button>
    </div>
  </div>

  <div
    id="mobile-nav"
    hidden
    class="lg:hidden border-t border-(--color-forest)/10 bg-(--color-cream)"
  >
    <nav class="max-w-[1200px] mx-auto px-6 py-4 flex flex-col gap-3" aria-label="Điều hướng di động">
      {nav.links.map((link) => (
        <a
          href={link.href}
          class="text-base font-medium text-(--color-forest) py-2 focus-ring-forest rounded-sm"
          data-mobile-nav-link
        >
          {link.label}
        </a>
      ))}
    </nav>
  </div>
</header>

<script>
  const toggle = document.getElementById("mobile-nav-toggle");
  const drawer = document.getElementById("mobile-nav");
  if (toggle && drawer) {
    toggle.addEventListener("click", () => {
      const expanded = toggle.getAttribute("aria-expanded") === "true";
      toggle.setAttribute("aria-expanded", String(!expanded));
      drawer.hidden = expanded;
    });
    drawer.querySelectorAll("[data-mobile-nav-link]").forEach((el) => {
      el.addEventListener("click", () => {
        toggle.setAttribute("aria-expanded", "false");
        drawer.hidden = true;
      });
    });
  }
</script>
